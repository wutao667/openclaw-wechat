{
  "name": "openclaw-webchat-plugin",
  "version": "0.1.1",
  "description": "WebChat channel plugin for OpenClaw — browser chat via WebSocket, no third-party IM needed",
  "type": "module",
  "main": "index.js",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "channel": {
      "id": "webchat",
      "label": "WebChat",
      "selectionLabel": "WebChat",
      "blurb": "Browser chat channel for OpenClaw"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wutao667/openclaw-wechat.git"
  },
  "keywords": [
    "openclaw",
    "webchat",
    "chat",
    "channel",
    "plugin"
  ]
}
